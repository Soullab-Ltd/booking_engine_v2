  addOns: {
    foodPass: boolean;
    adventurePass: boolean;
    extraStay: {
      enabled: boolean;
      days: number;
      type: string;
      startDate: string;
    };
  };
  remark: string;

  gender: 'Male' | 'Female' | 'Prefer not to say' | ''; 
  city: string;  
  state: string; 
  country: string;
}



