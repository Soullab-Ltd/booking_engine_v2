  time: string;
  title: string;
  description: string;
}

export interface ScheduleDay {
  day: string;
  date: string;
  slots: ScheduleSlot[];
}

export interface Plan {
  id?: string;
  planID: number;
  title?: string;
  sequence:number;
  PlanTitle?: string;
  thumbnail?: string;
  banner: string | null;
  description?: string;
  stayRoomType?: string;
  PlanDescription?: string;
  fullDescription?: string;
  PlanPrice: number;
  OfferPrice: number;
  discountedPrice?: number;
  finalPrice?: number;
  gstDetails?: string;
  amenities?: PlanIcon[];
